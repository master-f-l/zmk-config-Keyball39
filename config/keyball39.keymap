#include <behaviors/mouse_keys.dtsi>
#include <dt-bindings/zmk/mouse.h>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

&lt {
    tapping-term-ms = <240>;
    flavor = "balanced";
    quick-tap-ms = <150>;
};

&mt {
    tapping-term-ms = <200>;
    flavor = "tap-preferred";
    quick-tap-ms = <150>;
};

/ {
    combos { compatible = "zmk,combos"; };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            label = "QWRT";
            bindings = <
&kp Q           &kp W         &kp E    &kp R        &kp T                                     &kp Y        &kp U        &kp I      &kp O              &kp P
&mt LEFT_ALT A  &mt LSHIFT S  &lt 3 D  &mt LCTRL F  &kp G                                     &kp H        &mt RCTRL J  &lt 4 K    &mt RIGHT_SHIFT L  &mt RIGHT_ALT SEMI
&kp Z           &kp X         &kp C    &kp V        &kp B                                     &kp N        &kp M        &mkp LCLK  &kp PERIOD         &kp SLASH
&none           &none         &none    &lt 1 TAB    &mt LEFT_GUI SPACE  &mo 5  &kp BACKSPACE  &lt 2 ENTER                                             &none
            >;
        };

        LH {
            label = "LH";
            bindings = <
&kp LG(TAB)  &kp LG(GRAVE)  &trans     &trans  &trans                        &kp INSERT  &kp DELETE        &kp TILDE  &kp K_BACK         &kp K_FORWARD
&trans       &trans         &mkp RCLK  &trans  &trans                        &kp LEFT    &kp DOWN          &kp UP     &kp RIGHT          &kp PIPE
&trans       &trans         &trans     &trans  &trans                        &kp GRAVE   &kp SINGLE_QUOTE  &kp COMMA  &kp DOUBLE_QUOTES  &kp BACKSLASH
&trans       &trans         &trans     &trans  &trans  &trans  &kp QUESTION  &kp ESC                                                     &trans
            >;
        };

        RH {
            label = "RH";
            bindings = <
&kp LA(TAB)  &kp LA(GRAVE)  &trans     &trans  &trans                  &trans    &trans         &kp PLUS        &kp PAGE_UP    &kp PAGE_DOWN
&trans       &trans         &kp EQUAL  &trans  &trans                  &kp HOME  &kp LEFT       &kp MINUS       &kp RIGHT      &kp END
&trans       &trans         &trans     &trans  &trans                  &trans    &kp LC(LS(C))  &kp UNDERSCORE  &kp LC(LS(V))  &trans
&trans       &trans         &trans     &trans  &trans  &trans  &trans  &trans                                                  &trans
            >;
        };

        SYM {
            label = "SYM";
            bindings = <
&trans  &trans  &trans  &trans  &trans                  &kp EXCLAMATION   &kp AT_SIGN        &kp HASH        &kp DOLLAR            &kp PERCENT
&trans  &trans  &trans  &trans  &trans                  &kp CARET         &kp AMPERSAND      &kp ASTERISK    &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS
&trans  &trans  &trans  &trans  &trans                  &kp LEFT_BRACKET  &kp RIGHT_BRACKET  &kp UNDERSCORE  &kp LEFT_BRACE        &kp RIGHT_BRACE
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans                                                                     &trans
            >;
        };

        NUM {
            bindings = <
&kp N1  &kp N2         &kp N3     &kp N4            &kp N5                  &trans  &trans  &trans  &trans  &trans
&kp N6  &kp N7         &kp N8     &kp N9            &kp N0                  &trans  &trans  &trans  &trans  &trans
&trans  &kp LESS_THAN  &kp EQUAL  &kp GREATER_THAN  &trans                  &trans  &trans  &trans  &trans  &trans
&trans  &trans         &trans     &trans            &trans  &trans  &trans  &trans                          &trans
            >;

            label = "NUM";
        };

        SNIPE {
            label = "SNIPE";
            bindings = <
&kp F1       &kp F2   &kp F3  &kp F4      &kp F5                                  &none                 &none         &kp F20          &kp C_BRIGHTNESS_DEC  &kp C_BRIGHTNESS_INC
&kp F6       &kp F7   &kp F8  &kp F9      &kp F10                                 &kp CAPS              &kp C_VOL_DN  &kp K_MUTE       &kp C_VOL_UP          &kp DEL
&kp F11      &kp F12  &none   &none       &none                                   &none                 &none         &kp PRINTSCREEN  &none                 &none
&bootloader  &none    &none   &bt BT_NXT  &bt BT_CLR  &none  &kp LC(PRINTSCREEN)  &kp LA(LEFT_CONTROL)                                                       &bootloader
            >;
        };
    };
};
